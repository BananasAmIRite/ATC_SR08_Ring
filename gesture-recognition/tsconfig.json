{
    "compilerOptions": {
        "target": "es6",
        "module": "esnext",
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "allowJs": true,
        "checkJs": false
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
